# ─── Server ──────────────────────────────────────────────
PORT=3000
PUBLIC_URL=https://your-ngrok-url.ngrok-free.app
DEFAULT_SITE_ID=default-site

# ─── Secrets (never commit the real .env) ────────────────
# 32-byte key as 64 hex chars: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_64_hex_chars
# Protects the dashboard + sync API. Any long random string.
DASHBOARD_API_KEY=replace_with_long_random_string

# ─── HubSpot (private app) ───────────────────────────────
HUBSPOT_ACCESS_TOKEN=pat-eu1-xxxxxxxx
HUBSPOT_CLIENT_SECRET=replace_with_app_client_secret   # used to verify webhook signatures
HUBSPOT_API_BASE=https://api.hubapi.com

# ─── Wix (OAuth app) ─────────────────────────────────────
WIX_APP_ID=replace_with_wix_app_id
WIX_APP_SECRET=replace_with_wix_app_secret
WIX_WEBHOOK_SECRET=shared_secret_for_wix_webhook_calls  # optional shared-secret for Velo-pushed events

# ─── Sync tuning ─────────────────────────────────────────
SYNC_DEDUPE_WINDOW_MS=120000
# Set to 1 in local dev to skip webhook signature checks. NEVER set in production.
WEBHOOK_DEV_BYPASS=0
